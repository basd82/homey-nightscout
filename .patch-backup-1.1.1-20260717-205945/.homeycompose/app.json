{
  "_comment": "This file is generated. Please edit .homeycompose/app.json instead.",
  "id": "nl.bfvddikkenberg.nightscout",
  "version": "1.1.0",
  "compatibility": ">=12.0.0",
  "sdk": 3,
  "platforms": [
    "local"
  ],
  "name": {
    "en": "Nightscout Monitor",
    "nl": "Nightscout Monitor"
  },
  "description": {
    "en": "Your glucose data, always within reach.",
    "nl": "Je glucosegegevens altijd binnen handbereik."
  },
  "category": [
    "tools"
  ],
  "brandColor": "#303030",
  "author": {
    "name": "B.F. van den Dikkenberg",
    "email": "bas@dikkenberg.net"
  },
  "license": "GPL-3.0-or-later",
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png"
  },
  "drivers": [
    {
      "name": {
        "en": "Nightscout",
        "nl": "Nightscout"
      },
      "class": "sensor",
      "capabilities": [
        "measure_glucose",
        "glucose_trend",
        "glucose_delta",
        "reservoir",
        "pump_battery",
        "cgm_battery",
        "loop_status"
      ],
      "images": {
        "small": "/drivers/nightscout/assets/images/small.png",
        "large": "/drivers/nightscout/assets/images/large.png"
      },
      "pair": [
        {
          "id": "credentials",
          "navigation": {
            "next": "list_devices"
          }
        },
        {
          "id": "list_devices",
          "template": "list_devices"
        }
      ],
      "id": "nightscout",
      "settings": [
        {
          "id": "unit",
          "type": "dropdown",
          "label": {
            "en": "Glucose unit",
            "nl": "Glucose-eenheid"
          },
          "value": "mmol",
          "values": [
            {
              "id": "mmol",
              "label": {
                "en": "mmol/L",
                "nl": "mmol/L"
              }
            },
            {
              "id": "mgdl",
              "label": {
                "en": "mg/dL",
                "nl": "mg/dL"
              }
            }
          ]
        },
        {
          "id": "refresh_interval",
          "type": "number",
          "label": {
            "en": "Refresh interval seconds",
            "nl": "Verversinterval seconden"
          },
          "value": 60,
          "min": 30,
          "max": 3600
        }
      ]
    }
  ],
  "source": "https://github.com/basd82/homey-nightscout",
  "support": "https://github.com/basd82/homey-nightscout/issues",
  "contributors": {
    "developers": [
      {
        "name": "B.F. van den Dikkenberg",
        "email": "bas@dikkenberg.net"
      }
    ]
  },
  "bugs": {
    "url": "https://github.com/basd82/homey-nightscout/issues"
  },
  "homepage": "https://github.com/basd82/homey-nightscout",
